# OpenRouter LLM
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.7
MAX_OUTPUT_TOKENS=8000

# Backtest
OPTIMIZE_METRIC=sharpe
DSR_GATE=false

# Webhook (scan alerts)
WEBHOOK_URL=
WEBHOOK_KIND=discord

# Alpaca (Phase 2, dry-run works without keys)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
